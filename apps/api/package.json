    "@nestjs/core": "^10.4.2",
    "@nestjs/platform-fastify": "^10.4.2",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.1",
    "reflect-metadata": "^0.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
