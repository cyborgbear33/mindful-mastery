{
  "name": "mindful-mastery",
  "version": "0.1.0",
  "private": true,
  "description": "Constitution-bound AI lesson generation system",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": "20.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild",
      "sharp",
      "sqlite3"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:app": "pnpm -r --parallel --filter @mindful-mastery/api --filter @mindful-mastery/web dev",
    "restart:dev": "bash scripts/dev-restart.sh",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  }
}
